NODE_ENV=development
PORT=3000
SERVICE_NAME=canias-bank-movement-integration
TIMEZONE=Europe/Istanbul

SCHEDULER_ENABLED=true
SCHEDULER_CRON=*/15 * * * *
DATA_EXTRACTION_DURATION_MINUTES=360
QUERY_OVERLAP_MINUTES=5
MOVEMENT_FILTER_CREDIT_ONLY=true
MAX_MANUAL_QUERY_RANGE_HOURS=24

BANK_HTTP_TIMEOUT_MS=30000
BANK_HTTP_MAX_RETRIES=2
BANK_HTTP_RETRY_DELAY_MS=1000
BANK_HTTP_MAX_RESPONSE_BYTES=5000000

DB_HOST=localhost
DB_PORT=1433
DB_NAME=canias_bank
DB_USER=sa
DB_PASSWORD=YourLocalOnly_SqlPassword123!
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=15000
DB_REQUEST_TIMEOUT_MS=30000

ZIRAAT_INSTITUTION_CODE=INST_PLACEHOLDER
ZIRAAT_PASSWORD=ZIRAAT_PASSWORD_PLACEHOLDER
ZIRAAT_CUSTOMER_NUMBER=0000000000
ZIRAAT_ADDITIONAL_NUMBER=000

VAKIFBANK_ENDPOINT=https://vakifbank-example.local/soap
VAKIFBANK_USERNAME=VAKIF_USER_PLACEHOLDER
VAKIFBANK_PASSWORD=VAKIF_PASSWORD_PLACEHOLDER
VAKIFBANK_ACCOUNT_NUMBER=0000000000000
VAKIFBANK_CLIENT_NUMBER=0000000

API_KEY_ENABLED=false
API_KEY=
SHUTDOWN_TIMEOUT_MS=30000
LOG_LEVEL=info
COMMIT_SHA=
